# HGY CareBoard Pro Suite v3
PORT=8080
APP_BASE_URL=http://localhost:8080
SESSION_SECRET=change_this_secret

# Email verification
# true = OTP printed in terminal and returned to browser for local testing
# false = real SMTP email
EMAIL_DEV_MODE=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM="HGY CareBoard <your_email@gmail.com>"

# AI analysis
# mock = internal rule-based analysis
# openai = use OpenAI-compatible endpoint if OPENAI_API_KEY is set
AI_MODE=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
